{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gencraft Studio GitHub Labels Schema",
  "description": "Validates the structure of github-labels.yml.",
  "type": "object",
  "properties": {
      "github_label_sets": {
          "type": "array",
          "items": {
              "type": "object",
              "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "target_repository_type": { "type": "string" },
                  "labels": {
                      "type": "array",
                      "items": {
                          "type": "object",
                          "properties": {
                              "name": { "type": "string" },
                              "color": { "type": "string", "pattern": "^[0-9a-fA-F]{6}$" },
                              "description": { "type": "string" }
                          },
                          "required": ["name", "color", "description"]
                      }
                  }
              },
              "required": ["name", "description", "target_repository_type", "labels"]
          }
      }
  },
  "required": ["github_label_sets"]
}
