{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gencraft Studio SSoT Taxonomy Schema",
  "description": "Validates the structure of taxonomy.yml, ensuring its alignment with SKOS principles.",
  "type": "object",
  "properties": {
      "artifact_class": { "$ref": "#/definitions/skosConceptArray" },
      "knowledge_classification_category": { "$ref": "#/definitions/skosConceptArray" },
      "knowledge_classification_type": {
          "description": "A list of specific knowledge artifact types.",
          "type": "array",
          "minItems": 1,
          "items": {
              "type": "object",
              "properties": {
                  "skos:prefLabel": { "$ref": "#/definitions/kebabCaseString" },
                  "skos:definition": { "type": "string" },
                  "skos:altLabel": {
                      "type": "array",
                      "items": { "type": "string" }
                  },
                  "skos:broader": { "$ref": "#/definitions/kebabCaseString" },
                  "category": { "$ref": "#/definitions/kebabCaseString" }
              },
              "required": ["skos:prefLabel"],
              "anyOf": [
                  { "required": ["category"] },
                  { "required": ["skos:broader"] }
              ]
          }
      },
      "studio_domain": { "$ref": "#/definitions/skosConceptArray" },
      "lifecycle_phase": { "$ref": "#/definitions/skosConceptArray" },
      "security_classification": { "$ref": "#/definitions/skosConceptArray" },
      "repository_type": { "$ref": "#/definitions/skosConceptArray" }
  },
  "required": [
      "artifact_class",
      "knowledge_classification_category",
      "knowledge_classification_type",
      "studio_domain",
      "lifecycle_phase",
      "security_classification",
      "repository_type"
  ],
  "definitions": {
      "kebabCaseString": {
          "type": "string",
          "description": "A machine-readable identifier in kebab-case or underscore-case.",
          "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
      },
      "skosConcept": {
          "type": "object",
          "properties": {
              "skos:prefLabel": { "$ref": "#/definitions/kebabCaseString" },
              "skos:definition": { "type": "string" }
          },
          "required": ["skos:prefLabel"]
      },
      "skosConceptArray": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/skosConcept" }
      }
  }
}
